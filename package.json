{
  "name": "academics-os",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "seed:courses": "dotenv -e .env.local -- tsx scripts/seed-courses.ts",
    "seed:transcript": "dotenv -e .env.local -- tsx scripts/seed-transcript.ts",
    "seed:knowledge": "dotenv -e .env.local -- tsx scripts/seed-knowledge.ts",
    "seed:scholarships": "dotenv -e .env.local -- tsx scripts/seed-scholarships.ts",
    "seed:all": "pnpm seed:courses && pnpm seed:transcript && pnpm seed:knowledge && pnpm seed:scholarships",
    "db:generate": "dotenv -e .env.local -- drizzle-kit generate",
    "db:push": "dotenv -e .env.local -- drizzle-kit push",
    "db:apply-rls": "dotenv -e .env.local -- tsx scripts/apply-rls.ts",
    "db:studio": "dotenv -e .env.local -- drizzle-kit studio",
    "db:prep": "dotenv -e .env.local -- tsx scripts/db-prep.ts",
    "backfill:clerk": "dotenv -e .env.local -- tsx scripts/backfill-clerk-user-id.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.95",
    "@ai-sdk/google-vertex": "^4.0.113",
    "@ai-sdk/react": "^3.0.160",
    "@base-ui/react": "^1.3.0",
    "@clerk/nextjs": "^7.2.7",
    "@neondatabase/serverless": "^1.1.0",
    "ai": "^6.0.158",
    "better-auth": "^1.6.9",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.38.0",
    "geist": "^1.7.0",
    "lucide-react": "^1.8.0",
    "next": "16.2.3",
    "next-themes": "^0.4.6",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.1",
    "csv-parse": "^6.2.1",
    "dotenv-cli": "^11.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "jsdom": "^29.1.0",
    "playwright": "^1.59.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^4.1.5"
  }
}
